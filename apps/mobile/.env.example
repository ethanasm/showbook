# tRPC target. https://localhost:3001 for an iOS simulator on the local web
# stack (dev cert); a LAN/tunnel URL for a physical device.
EXPO_PUBLIC_API_URL=https://localhost:3001

# Google OAuth client IDs (Google Cloud Console). All three are needed for
# native sign-in: expo-auth-session uses the WEB client ID as the ID-token
# audience even on iOS/Android, so it is NOT web-preview-only.
EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID_IOS=
EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID_ANDROID=
EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID_WEB=

# Google Maps key for the Map tab (react-native-maps). Optional on iOS
# (Apple Maps is the default provider); REQUIRED on Android — without it the
# Android map renders blank. Thread through EAS env/secrets for store builds.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
