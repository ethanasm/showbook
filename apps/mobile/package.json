{
  "name": "mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "test": "find lib/__tests__ components/__tests__ \\( -name '*.test.ts' -o -name '*.test.tsx' -o -name '*.test.cjs' \\) -print0 2>/dev/null | xargs -0 -I{} node --import tsx --test {}",
    "test:coverage": "mkdir -p coverage && find lib/__tests__ components/__tests__ \\( -name '*.test.ts' -o -name '*.test.tsx' -o -name '*.test.cjs' \\) -print0 2>/dev/null | xargs -0 node --import tsx --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/mobile-unit.info --test-reporter=spec --test-reporter-destination=stdout",
    "e2e:ios": "maestro test --env MAESTRO_E2E_TOKEN=\"${MAESTRO_E2E_TOKEN:-}\" --env MAESTRO_E2E_USER_JSON=\"${MAESTRO_E2E_USER_JSON:-}\" e2e/flows/",
    "e2e:dry": "node e2e/scripts/dry-run.mjs e2e/flows"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.11",
    "@react-native-community/netinfo": "^11.4.1",
    "@showbook/shared": "workspace:*",
    "@tanstack/react-query": "^5.99.2",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "expo": "~55.0.24",
    "expo-auth-session": "~55.0.16",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.15",
    "expo-font": "~55.0.7",
    "expo-image": "~55.0.10",
    "expo-image-picker": "~55.0.20",
    "expo-linking": "~55.0.15",
    "expo-location": "~55.1.10",
    "expo-media-library": "~55.0.17",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.14",
    "expo-secure-store": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-sqlite": "~55.0.16",
    "expo-status-bar": "~55.0.6",
    "expo-web-browser": "~55.0.16",
    "lucide-react-native": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-native": "0.83.6",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-maps": "1.27.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.4",
    "semver": "^7.7.4",
    "superjson": "^2.2.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@showbook/api": "workspace:*",
    "@testing-library/react-native": "^13.3.3",
    "@types/node": "^25.8.0",
    "@types/react": "^19.1.0",
    "babel-preset-expo": "~55.0.21",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.1",
    "react-test-renderer": "^19.2.6",
    "tsx": "^4.22.0",
    "typescript": "~6.0.3",
    "yaml": "^2.9.0"
  },
  "expo": {
    "install": {
      "exclude": [
        "react",
        "react-dom",
        "react-native-reanimated",
        "react-native-worklets"
      ]
    }
  }
}
