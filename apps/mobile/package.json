{
  "name": "mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "start:dev-client": "expo start --dev-client",
    "start:go": "expo start",
    "ios": "node ../../scripts/trust-ios-localhost-cert.mjs && expo run:ios",
    "ios:dev": "node ../../scripts/trust-ios-localhost-cert.mjs && expo run:ios",
    "ios:go": "expo start --ios",
    "android": "expo run:android",
    "android:dev": "expo run:android",
    "android:go": "expo start --android",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "test": "find lib/__tests__ components/__tests__ \\( -name '*.test.ts' -o -name '*.test.tsx' -o -name '*.test.cjs' \\) -print0 2>/dev/null | xargs -0 -I{} node --import tsx --test {}",
    "test:coverage": "mkdir -p coverage && find lib/__tests__ components/__tests__ \\( -name '*.test.ts' -o -name '*.test.tsx' -o -name '*.test.cjs' \\) -print0 2>/dev/null | xargs -0 node --import tsx --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/mobile-unit.info --test-reporter=spec --test-reporter-destination=stdout",
    "e2e:ios": "maestro test e2e/flows/",
    "e2e:dry": "node e2e/scripts/dry-run.mjs e2e/flows",
    "web:build": "EXPO_PUBLIC_E2E_MODE=1 expo export --platform web --output-dir dist-web --clear",
    "web:test": "playwright test --config=playwright.config.ts",
    "web:verify": "pnpm web:build && pnpm web:test"
  },
  "dependencies": {
    "@expo-google-fonts/fraunces": "^0.4.1",
    "@expo-google-fonts/geist": "^0.4.2",
    "@expo-google-fonts/geist-mono": "^0.4.2",
    "@expo/metro-runtime": "~56.0.13",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@showbook/shared": "workspace:*",
    "@tanstack/react-query": "^5.99.2",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "expo": "~56.0.6",
    "expo-audio": "~56.0.11",
    "expo-auth-session": "~56.0.12",
    "expo-constants": "~56.0.16",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.16",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.9",
    "expo-image-manipulator": "~56.0.15",
    "expo-image-picker": "~56.0.14",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.12",
    "expo-location": "~56.0.14",
    "expo-notifications": "~56.0.14",
    "expo-router": "~56.2.7",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-sqlite": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.17",
    "expo-web-browser": "~56.0.5",
    "fflate": "^0.8.3",
    "lucide-react-native": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-native": "0.85.3",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-maps": "1.27.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.8.3",
    "semver": "^7.7.4",
    "showbook-spotify-sdk": "file:./modules/showbook-spotify-sdk",
    "superjson": "^2.2.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@playwright/test": "^1.60.0",
    "@showbook/api": "workspace:*",
    "@testing-library/react-native": "^13.3.3",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "babel-preset-expo": "~56.0.13",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~56.0.4",
    "react-test-renderer": "^19.2.6",
    "tsx": "^4.22.3",
    "typescript": "~6.0.3",
    "yaml": "^2.9.0"
  },
  "expo": {
    "install": {
      "exclude": [
        "react",
        "react-dom"
      ]
    },
    "autolinking": {
      "ios": {
        "exclude": [
          "expo-image-loader"
        ]
      }
    }
  }
}
