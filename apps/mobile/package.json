{
  "name": "mobile",
  "version": "0.1.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "start:dev-client": "expo start --dev-client",
    "start:go": "expo start",
    "ios": "node ../../scripts/trust-ios-localhost-cert.mjs && expo run:ios",
    "ios:dev": "node ../../scripts/trust-ios-localhost-cert.mjs && expo run:ios",
    "ios:go": "expo start --ios",
    "android": "expo run:android",
    "android:dev": "expo run:android",
    "android:go": "expo start --android",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "test": "find lib/__tests__ components/__tests__ \\( -name '*.test.ts' -o -name '*.test.tsx' -o -name '*.test.cjs' \\) -print0 2>/dev/null | xargs -0 -I{} node --import tsx --test {}",
    "test:coverage": "mkdir -p coverage && find lib/__tests__ components/__tests__ \\( -name '*.test.ts' -o -name '*.test.tsx' -o -name '*.test.cjs' \\) -print0 2>/dev/null | xargs -0 node --import tsx --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/mobile-unit.info --test-reporter=spec --test-reporter-destination=stdout",
    "e2e:ios": "maestro test e2e/flows/",
    "e2e:dry": "node e2e/scripts/dry-run.mjs e2e/flows",
    "web:build": "EXPO_PUBLIC_E2E_MODE=1 expo export --platform web --output-dir dist-web --clear",
    "web:test": "playwright test --config=playwright.config.ts",
    "web:verify": "pnpm web:build && pnpm web:test"
  },
  "dependencies": {
    "@expo-google-fonts/fraunces": "^0.4.1",
    "@expo-google-fonts/geist": "^0.4.2",
    "@expo-google-fonts/geist-mono": "^0.4.2",
    "@expo/metro-runtime": "~57.0.5",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@showbook/shared": "workspace:*",
    "@tanstack/react-query": "^5.101.2",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.18.0",
    "expo": "~57.0.6",
    "expo-audio": "~57.0.2",
    "expo-auth-session": "~57.0.3",
    "expo-constants": "~57.0.5",
    "expo-crypto": "~57.0.1",
    "expo-dev-client": "~57.0.6",
    "expo-file-system": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-haptics": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-image-manipulator": "~57.0.4",
    "expo-image-picker": "~57.0.4",
    "expo-linear-gradient": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-location": "~57.0.4",
    "expo-notifications": "~57.0.5",
    "expo-router": "~57.0.6",
    "expo-secure-store": "~57.0.1",
    "expo-splash-screen": "~57.0.4",
    "expo-sqlite": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "expo-updates": "~57.0.7",
    "expo-web-browser": "~57.0.1",
    "fflate": "^0.8.3",
    "lucide-react-native": "^1.17.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-maps": "1.29.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.5",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.10.0",
    "semver": "^7.8.1",
    "showbook-spotify-sdk": "file:./modules/showbook-spotify-sdk",
    "superjson": "^2.2.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@playwright/test": "^1.61.1",
    "@showbook/api": "workspace:*",
    "@testing-library/react-native": "^14.0.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.15",
    "babel-preset-expo": "~57.0.3",
    "eslint": "^9.39.5",
    "eslint-config-expo": "~57.0.0",
    "react-test-renderer": "19.2.3",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3",
    "yaml": "^2.9.0"
  },
  "expo": {
    "autolinking": {
      "ios": {
        "exclude": [
          "expo-image-loader"
        ]
      }
    }
  }
}
