# Showbook env template.
#
# This file documents every variable read by the app, jobs, and tests.
# It's not loaded by anything itself — copy it to one of:
#
#   apps/web/.env.local   used by `pnpm dev` outside Docker (Next.js native loader)
#   .env.dev              used by docker-compose.yml (dev compose) — usually empty
#   .env.prod             used by docker-compose.prod.yml (prod compose) — REQUIRED
#
# Whichever file you use, comment out variables that don't apply (see the
# Database section below for the most important case).

# === Database ===
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
#
# Dev and prod use distinct postgres host ports, database names, and
# roles so workspace scripts can never accidentally touch prod data:
#
#   Dev:  localhost:5433  db=showbook       role=showbook       password=showbook_dev
#   E2E:  localhost:5433  db=showbook_e2e   role=showbook       (same container as dev)
#   Prod: localhost:5434  db=showbook_prod  role=showbook_prod  password=$POSTGRES_PASSWORD
#
# The CLI guard at scripts/guard-not-prod-db.mjs refuses to run any
# dev/test workspace command whose DATABASE_URL points at a database
# named showbook_prod*; prod migrations must go through `pnpm prod:migrate`.
#
# How DATABASE_URL gets set depends on how Showbook is run:
#
#   pnpm dev outside Docker (apps/web/.env.local):
#     Set DATABASE_URL below. POSTGRES_PASSWORD is unused.
#
#   Dev compose, docker-compose.yml (.env.dev):
#     Don't set either. The compose hardcodes both with the dev defaults
#     (user=showbook, password=showbook_dev). The container's DATABASE_URL
#     points at the postgres service inside the docker network.
#
#   Prod compose, docker-compose.prod.yml (.env.prod):
#     Set POSTGRES_PASSWORD only. The compose builds DATABASE_URL from it
#     (postgresql://showbook_prod:$POSTGRES_PASSWORD@postgres:5432/showbook_prod).
#     Setting DATABASE_URL too is silently ignored (the compose's
#     `environment:` overrides env_file values), but it's a sync hazard —
#     leave it commented out.

# Pick ONE of the next two lines based on the table above.
DATABASE_URL=postgresql://showbook:showbook_dev@localhost:5433/showbook
# POSTGRES_PASSWORD=$(openssl rand -base64 32)

# Workspace scripts (db:migrate, db:prepare:e2e, test:integration, test:e2e)
# read DEV_/E2E_DATABASE_URL so a single shell can target both DBs without
# accidentally pointing destructive resets at the wrong one. Both have safe
# defaults that match the docker-compose postgres on port 5433.
# DEV_DATABASE_URL=postgresql://showbook:showbook_dev@localhost:5433/showbook
# E2E_DATABASE_URL=postgresql://showbook:showbook_dev@localhost:5433/showbook_e2e

# Auth (NextAuth)
# In prod, NEXTAUTH_URL must match the Cloudflare Tunnel hostname AND the
# OAuth redirect URI registered with Google for /api/auth/callback/google
# and /api/gmail/callback.
#
# Web host ports by stack:
#   Dev (docker-compose.yml or `pnpm dev`):    https://localhost:3001
#   Prod local testing (docker-compose.prod):  https://localhost:3002
#   Real prod:                                 the Cloudflare Tunnel hostname
#   E2E Playwright (pnpm test:e2e):            https://localhost:3003
NEXTAUTH_URL=https://localhost:3001
# Use a long unique value in prod: `openssl rand -base64 48`
AUTH_SECRET=replace-with-a-long-random-string
# Legacy alias still read by some code paths; OK to set both to the same value.
NEXTAUTH_SECRET=replace-with-a-long-random-string
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Spotify (followed-artist import on /preferences). Register a redirect URI
# matching NEXTAUTH_URL + /api/spotify/callback in the Spotify dashboard
# (https://developer.spotify.com/dashboard). The OAuth flow runs in a popup
# and never persists the access token.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Sign-in allowlist. Comma-separated. Either match grants access.
# Both empty = open mode (anyone with a Google account can sign in).
# Set at least one of these in .env.prod before going live.
AUTH_ALLOWED_EMAILS=
AUTH_ALLOWED_DOMAINS=

# Public app URL (used in email links, OG tags, etc.).
# Match the NEXTAUTH_URL host: dev → 3001, local prod → 3002,
# real prod → tunnel hostname.
NEXT_PUBLIC_APP_URL=https://localhost:3001

# Data sources
TICKETMASTER_API_KEY=
SETLISTFM_API_KEY=
GROQ_API_KEY=
GOOGLE_PLACES_API_KEY=

# Cloudflare R2 (photo/video storage)
# Create an R2 bucket and a bucket-scoped Object Read & Write token.
# The account ID is the value in https://<ACCOUNT_ID>.r2.cloudflarestorage.com.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=showbook
R2_PUBLIC_URL=

# Media storage mode
# r2 = Cloudflare R2, local = development-only uploads to apps/web/public/media-uploads,
# disabled = block media uploads.
MEDIA_STORAGE_MODE=r2

# Media quotas — defaults keep app-managed media below R2's free 10 GB storage tier.
MEDIA_GLOBAL_QUOTA_BYTES=8589934592
MEDIA_USER_QUOTA_BYTES=1073741824
MEDIA_SHOW_QUOTA_BYTES=314572800
MEDIA_PHOTO_MAX_SOURCE_BYTES=20971520
MEDIA_PHOTO_MAX_STORED_BYTES=5242880
MEDIA_VIDEO_MAX_BYTES=157286400
MEDIA_SHOW_MAX_PHOTOS=30
MEDIA_SHOW_MAX_VIDEOS=2

# Media URL security
MEDIA_UPLOAD_URL_TTL_SECONDS=900
MEDIA_READ_URL_TTL_SECONDS=3600
MEDIA_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/heic,image/heif
MEDIA_ALLOWED_VIDEO_TYPES=video/mp4

# Per-user cost guardrails. Defaults are conservative; raise for trusted
# self-hosters or lower for hosted demos. See GUARDRAILS.md for the full
# list of enforcement points.
# SHOWBOOK_LLM_CALLS_PER_DAY=50
# SHOWBOOK_BULK_SCAN_PER_HOUR=5
# SHOWBOOK_BULK_SCAN_MESSAGE_CAP=200

# Email (Resend) — daily digest delivery
# When unset the digest job logs what it would send and skips delivery.
RESEND_API_KEY=
EMAIL_FROM=Showbook <digest@example.com>

# Observability — optional. Langfuse activates when both keys are set;
# Axiom log shipping activates when both AXIOM_TOKEN and AXIOM_DATASET are set.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=https://cloud.langfuse.com
AXIOM_TOKEN=
AXIOM_DATASET=showbook
# LOG_LEVEL=debug

# E2E test harness — DO NOT set in .env.prod. The `/api/test/*` routes
# require ALL THREE: NODE_ENV !== 'production', ENABLE_TEST_ROUTES=1, and
# DATABASE_URL pointing at TEST_DATABASE_NAME (default `showbook_e2e`).
# ENABLE_TEST_ROUTES=1
# TEST_DATABASE_NAME=showbook_e2e

# NODE_ENV is set automatically:
#   - docker-compose.prod.yml hardcodes NODE_ENV=production
#   - docker-compose.yml leaves it unset (server.mjs runs Next in dev mode)
#   - `next start` / `next build` set it themselves
# Don't set NODE_ENV in your env files.
