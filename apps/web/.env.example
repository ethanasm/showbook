# Database
# DATABASE_URL is what the running app + jobs read at runtime. Point it at
# whichever database this Next.js process should serve.
DATABASE_URL=postgresql://showbook:showbook_dev@localhost:5433/showbook
# Workspace scripts (db:migrate, db:prepare:e2e, test:integration, test:e2e)
# read DEV_/E2E_DATABASE_URL so a single shell can target both DBs without
# accidentally pointing destructive resets at the wrong one. Both have safe
# defaults that match the docker-compose postgres on port 5433.
# DEV_DATABASE_URL=postgresql://showbook:showbook_dev@localhost:5433/showbook
# E2E_DATABASE_URL=postgresql://showbook:showbook_dev@localhost:5433/showbook_e2e

# Auth (NextAuth)
NEXTAUTH_URL=https://localhost:3001
NEXTAUTH_SECRET=replace-with-a-long-random-string
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sign-in allowlist. Comma-separated. Either match grants access.
# Both empty = open mode (anyone with a Google account can sign in).
AUTH_ALLOWED_EMAILS=
AUTH_ALLOWED_DOMAINS=

# Public app URL (used in email links, OG tags, etc.)
NEXT_PUBLIC_APP_URL=https://localhost:3001

# Data sources
TICKETMASTER_API_KEY=
SETLISTFM_API_KEY=
GROQ_API_KEY=
GOOGLE_PLACES_API_KEY=

# Cloudflare R2 (photo/video storage)
# Create an R2 bucket and a bucket-scoped Object Read & Write token.
# The account ID is the value in https://<ACCOUNT_ID>.r2.cloudflarestorage.com.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=showbook
R2_PUBLIC_URL=

# Media storage mode
# r2 = Cloudflare R2, local = development-only uploads to apps/web/public/media-uploads,
# disabled = block media uploads.
MEDIA_STORAGE_MODE=r2

# Media quotas — defaults keep app-managed media below R2's free 10 GB storage tier.
MEDIA_GLOBAL_QUOTA_BYTES=8589934592
MEDIA_USER_QUOTA_BYTES=1073741824
MEDIA_SHOW_QUOTA_BYTES=314572800
MEDIA_PHOTO_MAX_SOURCE_BYTES=20971520
MEDIA_PHOTO_MAX_STORED_BYTES=5242880
MEDIA_VIDEO_MAX_BYTES=157286400
MEDIA_SHOW_MAX_PHOTOS=30
MEDIA_SHOW_MAX_VIDEOS=2

# Media URL security
MEDIA_UPLOAD_URL_TTL_SECONDS=900
MEDIA_READ_URL_TTL_SECONDS=3600
MEDIA_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/heic,image/heif
MEDIA_ALLOWED_VIDEO_TYPES=video/mp4

# Per-user cost guardrails. Defaults are conservative; raise for trusted
# self-hosters or lower for hosted demos. See GUARDRAILS.md for the full
# list of enforcement points.
# SHOWBOOK_LLM_CALLS_PER_DAY=50
# SHOWBOOK_BULK_SCAN_PER_HOUR=5
# SHOWBOOK_BULK_SCAN_MESSAGE_CAP=200

# Email (Resend) — daily digest delivery
# When unset the digest job logs what it would send and skips delivery.
RESEND_API_KEY=
EMAIL_FROM=Showbook <digest@example.com>

# Observability — optional. Langfuse activates when both keys are set;
# Axiom log shipping activates when both AXIOM_TOKEN and AXIOM_DATASET are set.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=https://cloud.langfuse.com
AXIOM_TOKEN=
AXIOM_DATASET=showbook
# LOG_LEVEL=debug

# E2E test harness — DO NOT set in production
# ENABLE_TEST_ROUTES=1
# TEST_DATABASE_NAME=showbook_e2e
