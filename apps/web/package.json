{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001 --experimental-https",
    "dev:e2e": "DATABASE_URL=\"${E2E_DATABASE_URL:-postgresql://showbook:showbook_dev@localhost:5433/showbook_e2e}\" ENABLE_TEST_ROUTES=1 NEXTAUTH_URL=https://localhost:${PLAYWRIGHT_PORT:-3003} AUTH_SECRET=showbook-e2e-secret NEXTAUTH_SECRET=showbook-e2e-secret next dev --port ${PLAYWRIGHT_PORT:-3003} --experimental-https",
    "start:e2e": "DATABASE_URL=\"${E2E_DATABASE_URL:-postgresql://showbook:showbook_dev@localhost:5433/showbook_e2e}\" ENABLE_TEST_ROUTES=1 NEXTAUTH_URL=http://localhost:${PLAYWRIGHT_PORT:-3003} AUTH_SECRET=showbook-e2e-secret NEXTAUTH_SECRET=showbook-e2e-secret next start --port ${PLAYWRIGHT_PORT:-3003}",
    "build": "next build",
    "start": "next start --port 3001",
    "lint": "eslint .",
    "test": "TSX_TSCONFIG_PATH=tsconfig.test.json find lib/__tests__ components/__tests__ \\( -name '*.test.ts' -o -name '*.test.tsx' \\) -not -name '*.integration.test.ts' -print0 | xargs -0 env TSX_TSCONFIG_PATH=tsconfig.test.json node --import tsx --import ./test-setup.ts --test",
    "test:coverage": "mkdir -p coverage && find lib/__tests__ components/__tests__ \\( -name '*.test.ts' -o -name '*.test.tsx' \\) -not -name '*.integration.test.ts' -print0 | xargs -0 env TSX_TSCONFIG_PATH=tsconfig.test.json node --import tsx --import ./test-setup.ts --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/unit.info --test-reporter=spec --test-reporter-destination=stdout",
    "test:integration": "node ../../scripts/run-integration.mjs apps/web",
    "test:integration:coverage": "mkdir -p coverage && LCOV_OUT=$PWD/coverage/integration.info node ../../scripts/run-integration.mjs apps/web --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "google-auth-library": "^9.14.0",
    "@axiomhq/pino": "^1.5.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@showbook/api": "workspace:*",
    "@showbook/db": "workspace:*",
    "@showbook/jobs": "workspace:*",
    "@showbook/observability": "workspace:*",
    "@showbook/shared": "workspace:*",
    "@tanstack/react-query": "^5.100.6",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.0.0",
    "geist": "^1.4.1",
    "heic-to": "^1.4.2",
    "langfuse": "^3.38.4",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.9.0",
    "next": "^15.3.1",
    "next-auth": "5.0.0-beta.31",
    "pdf-parse": "1.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-leaflet": "^5.0.0",
    "superjson": "^2.2.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "global-jsdom": "^29.0.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
