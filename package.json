{
  "name": "showbook",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "nx dev web",
    "build": "nx build web",
    "lint": "nx lint web",
    "db:generate": "DATABASE_URL=postgresql://showbook:showbook_dev@localhost:5433/showbook pnpm --filter @showbook/db drizzle-kit generate",
    "db:migrate": "DATABASE_URL=postgresql://showbook:showbook_dev@localhost:5433/showbook pnpm --filter @showbook/db drizzle-kit migrate",
    "db:create:e2e": "docker compose exec -T postgres sh -c \"psql -U showbook -d showbook -tAc \\\"SELECT 1 FROM pg_database WHERE datname = 'showbook_e2e'\\\" | grep -q 1 || createdb -U showbook showbook_e2e\"",
    "db:reset:e2e": "docker compose exec -T postgres sh -c \"psql -U showbook -d showbook -c 'DROP DATABASE IF EXISTS showbook_e2e WITH (FORCE);' && psql -U showbook -d showbook -c 'CREATE DATABASE showbook_e2e;'\"",
    "db:migrate:e2e": "DATABASE_URL=postgresql://showbook:showbook_dev@localhost:5433/showbook_e2e pnpm --filter @showbook/db drizzle-kit migrate",
    "db:prepare:e2e": "pnpm db:reset:e2e && pnpm db:migrate:e2e",
    "db:studio": "DATABASE_URL=postgresql://showbook:showbook_dev@localhost:5433/showbook pnpm --filter @showbook/db drizzle-kit studio",
    "test:e2e": "pnpm db:prepare:e2e && pnpm --filter web test:e2e"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "nx": "^20.4.0",
    "typescript": "^5.7.0"
  }
}
