**/node_modules/**
**/.next/**
*.png
.git

# Never bake env files into the image — secrets land in layer cache
# and any registry push.
.env
.env.local
.env.*.local
.env.dev
.env.prod
.env.production
.env.production.*
.env.development
.env.development.*

# Local mkcert dev certs — bind-mounted into the dev container, never
# baked into prod (would make prod serve HTTPS on a port the Cloudflare
# Tunnel expects to be plain HTTP).
certs/
