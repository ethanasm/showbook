**/node_modules/**
**/.next/**
*.png
.git

# Never bake env files into the image — secrets land in layer cache
# and any registry push.
.env
.env.local
.env.*.local
.env.dev
.env.prod
.env.production
.env.production.*
.env.development
.env.development.*

# Local TLS dev certs. Never bake into prod images:
#   - ./certs (mkcert root for the loopback hostname; bind-mounted into
#     dev so HTTPS works locally). Baking it would make server.mjs serve
#     HTTPS on the prod loopback port that the Cloudflare Tunnel ingress
#     expects to be plain HTTP, causing 502s.
#   - apps/web/certificates (auto-generated by next dev --experimental-https)
#   - any stray *.pem / *-key.pem (defense-in-depth)
certs/
apps/web/certificates/
**/*.pem
