{
  "name": "@showbook/jobs",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "run-daily-digest": "tsx scripts/run-daily-digest.ts",
    "email:smoke": "tsx scripts/email-smoke.ts",
    "bootstrap-pgboss": "node scripts/bootstrap-pgboss.mjs",
    "test": "find src/__tests__ -name '*.test.ts' -not -name '*.integration.test.ts' -print0 | xargs -0 node --import tsx --test",
    "test:coverage": "mkdir -p coverage && find src/__tests__ -name '*.test.ts' -not -name '*.integration.test.ts' -print0 | xargs -0 node --import tsx --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/unit.info --test-reporter=spec --test-reporter-destination=stdout",
    "test:integration": "node ../../scripts/run-integration.mjs packages/jobs",
    "test:integration:coverage": "mkdir -p coverage && LCOV_OUT=$PWD/coverage/integration.info node ../../scripts/run-integration.mjs packages/jobs --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@showbook/api": "workspace:*",
    "@showbook/db": "workspace:*",
    "@showbook/emails": "workspace:*",
    "@showbook/observability": "workspace:*",
    "@showbook/scrapers": "workspace:*",
    "@showbook/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "pg-boss": "^10.1.0",
    "resend": "^6.12.2"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
