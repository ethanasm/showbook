{
  "name": "@showbook/emails",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "dev": "email dev --dir src/preview --port 3030",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint --no-config-lookup -c ../../eslint.config.packages.mjs src",
    "test": "find src/__tests__ \\( -name '*.test.ts' -o -name '*.test.tsx' \\) -print0 | xargs -0 node --import tsx --test",
    "test:coverage": "mkdir -p coverage && find src/__tests__ \\( -name '*.test.ts' -o -name '*.test.tsx' \\) -print0 | xargs -0 node --import tsx --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/unit.info --test-reporter=spec --test-reporter-destination=stdout"
  },
  "dependencies": {
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.9",
    "@react-email/tailwind": "^2.0.7",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.1.0",
    "react-email": "^6.6.6",
    "tsx": "^4.23.0",
    "typescript": "~6.0.3"
  }
}
