{
  "name": "@showbook/scrapers",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "run": "tsx src/cli.ts",
    "test": "find src/__tests__ -name '*.test.ts' -print0 | xargs -0 node --import tsx --test",
    "test:coverage": "mkdir -p coverage && find src/__tests__ -name '*.test.ts' -print0 | xargs -0 node --import tsx --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/unit.info --test-reporter=spec --test-reporter-destination=stdout",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint --no-config-lookup -c ../../eslint.config.packages.mjs src"
  },
  "dependencies": {
    "@showbook/api": "workspace:*",
    "@showbook/db": "workspace:*",
    "@showbook/observability": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "groq-sdk": "^1.2.1",
    "playwright": "^1.61.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3"
  }
}
