{
  "name": "@showbook/api",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "test": "find src/__tests__ -name '*.test.ts' -not -name '*.integration.test.ts' -print0 | xargs -0 node --import tsx --test --experimental-test-module-mocks",
    "test:coverage": "mkdir -p coverage && find src/__tests__ -name '*.test.ts' -not -name '*.integration.test.ts' -print0 | xargs -0 node --import tsx --test --experimental-test-module-mocks --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/unit.info --test-reporter=spec --test-reporter-destination=stdout",
    "test:integration": "node ../../scripts/run-integration.mjs packages/api",
    "test:integration:coverage": "mkdir -p coverage && LCOV_OUT=$PWD/coverage/integration.info node ../../scripts/run-integration.mjs packages/api --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "probe-audio-features": "tsx scripts/probe-audio-features.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1051.0",
    "@aws-sdk/s3-request-presigner": "^3.1051.0",
    "@showbook/db": "workspace:*",
    "@showbook/observability": "workspace:*",
    "@showbook/shared": "workspace:*",
    "@trpc/server": "^11.0.0",
    "drizzle-orm": "^0.45.2",
    "groq-sdk": "^1.1.2",
    "pg-boss": "^10.1.0",
    "superjson": "^2.2.6",
    "unpdf": "^1.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsx": "^4.22.0",
    "typescript": "~5.9.2"
  }
}
