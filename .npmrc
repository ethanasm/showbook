public-hoist-pattern[]=*pino*
public-hoist-pattern[]=@axiomhq/*
public-hoist-pattern[]=thread-stream
# Hoist everything else so Metro (apps/mobile) can resolve the long
# tail of transitive deps that Expo / RN packages import inline.
# disableHierarchicalLookup: true in metro.config.js means Metro only
# looks in the workspace + app node_modules — not pnpm's nested store —
# so pnpm needs to behave like npm/yarn for this monorepo.
public-hoist-pattern[]=*

# Tolerate flaky registry edges. Defaults (2 retries / 10s min / 60s max)
# burn down before npm's CDN recovers; the prod runner has been losing
# whole `pnpm prod:up` builds to single-tarball ECONNRESETs (expo-image,
# next, sharp musl, etc.) that exhaust the retry budget mid-install.
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
