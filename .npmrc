public-hoist-pattern[]=*pino*
public-hoist-pattern[]=@axiomhq/*
public-hoist-pattern[]=thread-stream
# Hoist Metro-resolvable Expo / React Native transitive deps so the
# monorepo apps/mobile bundler can find them. metro.config.js sets
# `disableHierarchicalLookup: true` and only adds the workspace + app
# node_modules to the resolver, so transitive deps that Expo / RN
# packages import directly (whatwg-fetch, anser, stacktrace-parser,
# etc.) need to be at the top-level node_modules to be reachable.
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=whatwg-fetch
public-hoist-pattern[]=anser
public-hoist-pattern[]=stacktrace-parser
public-hoist-pattern[]=pretty-format
