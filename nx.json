{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "dev": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "cache": true
    },
    "test": {
      "cache": true,
      "inputs": ["default", "^default"]
    },
    "test:coverage": {
      "cache": true,
      "inputs": ["default", "^default"],
      "outputs": ["{projectRoot}/coverage"]
    },
    "test:integration": {
      "cache": true,
      "inputs": ["default", "^default", { "env": "DATABASE_URL" }]
    },
    "test:integration:coverage": {
      "cache": true,
      "inputs": ["default", "^default", { "env": "DATABASE_URL" }],
      "outputs": ["{projectRoot}/coverage"]
    }
  },
  "defaultBase": "main"
}
